# Copy this file to .env and fill in real values before running.

# MongoDB Atlas connection string (required for live DB; JSON fallback works without it)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# OpenAI API key (required for GPT explanations; fallback explanation used without it)
OPENAI_API_KEY=sk-...

# Comma-separated allowed CORS origins
CORS_ORIGINS=http://localhost:5173

# Optional: allow prerecorded demo fingerprints to bypass live matching
ENABLE_DEMO_CACHE=false

# Optional: small upward bias applied to displayed confidence scores
DISPLAY_CONFIDENCE_BIAS=0.06
